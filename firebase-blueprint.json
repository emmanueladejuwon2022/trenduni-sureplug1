{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the system.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "walletBalance": { "type": "string" },
        "contextRequestId": { "type": "string" },
        "contextRequestText": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "Vendor profile details.",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "description": { "type": "string" },
        "contact": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" }
            }
          }
        },
        "portfolio": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Request": {
      "title": "Request",
      "description": "A request made by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "budget": { "type": "string" },
        "status": { "type": "string" },
        "assignedVendorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "description", "status"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Chat session.",
      "type": "object",
      "properties": {
        "participants": {
          "type": "array",
          "items": { "type": "string" }
        },
        "contextRequestId": { "type": "string" },
        "contextRequestText": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    },
    "Escrow": {
      "title": "Escrow",
      "description": "An escrow transaction.",
      "type": "object",
      "properties": {
        "buyerId": { "type": "string" },
        "vendorId": { "type": "string" },
        "participants": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requestId": { "type": "string" },
        "amount": { "type": "string" },
        "status": { "type": "string", "enum": ["held", "released", "refunded", "disputed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "vendorId", "participants", "amount", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet transaction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "string" },
        "type": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "description"]
    },
    "Dispute": {
      "title": "Dispute",
      "description": "A dispute over an escrow.",
      "type": "object",
      "properties": {
        "escrowId": { "type": "string" },
        "reportedBy": { "type": "string" },
        "otherUserId": { "type": "string" },
        "amount": { "type": "string" },
        "reason": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "resolution": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["escrowId", "reportedBy", "otherUserId", "amount", "reason", "description", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Vendor review.",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string" },
        "userId": { "type": "string" },
        "requestId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["vendorId", "userId", "rating", "comment", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "Withdrawal request.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "string" },
        "paymentInfo": { "type": "object" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "paymentInfo", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User documents."
    },
    "/vendors/{vendorId}": {
      "schema": { "$ref": "#/entities/Vendor" },
      "description": "Vendor configuration data."
    },
    "/requests/{requestId}": {
      "schema": { "$ref": "#/entities/Request" },
      "description": "Requests made by users."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chat conversations."
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Chat messages."
    },
    "/escrows/{escrowId}": {
      "schema": { "$ref": "#/entities/Escrow" },
      "description": "Escrow transactions."
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Wallet transactions."
    },
    "/disputes/{disputeId}": {
      "schema": { "$ref": "#/entities/Dispute" },
      "description": "Escrow disputes."
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Vendor reviews."
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User notifications."
    },
    "/withdrawals/{withdrawalId}": {
      "schema": { "$ref": "#/entities/Withdrawal" },
      "description": "Funds withdrawal requests."
    }
  }
}
